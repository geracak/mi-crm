# --- Convex (backend) ---
# URL pública del deployment de Convex. En local se rellena sola al ejecutar
# `npx convex dev`. En Railway hay que definirla a mano, apuntando al deployment
# de Convex que uses para producción. Es IMPRESCINDIBLE en build y en runtime
# (la usa el cliente en src/app/providers.tsx).
NEXT_PUBLIC_CONVEX_URL=

# Deploy key de Convex — SOLO para uso local/CI al ejecutar `npx convex deploy`.
# Con la configuración actual (Railway solo publica la web) NO hace falta en
# Railway: el backend Convex se despliega por separado. No commitear el valor real.
# CONVEX_DEPLOY_KEY=
