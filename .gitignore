# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example

# vercel
.vercel

# convex/_generated is intentionally COMMITTED, not ignored here: in
# `convex deploy --cmd "next build"`, the wrapped build command runs before
# codegen/push finish, so a fresh Railway clone has no convex/_generated at
# all when `next build` resolves its imports (confirmed via a real failed
# Railway build - "Module not found: .../convex/_generated/api"). It's
# regenerated locally by `npx convex dev` and re-committed like any other
# generated-but-required build input (e.g. package-lock.json).

# claude code local settings
**/.claude/settings.local.json

# typescript
*.tsbuildinfo
next-env.d.ts
