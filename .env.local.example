NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# NOT read from this file - this is a Convex deployment environment variable,
# set per-deployment via `npx convex env set ALLOW_DEV_SEED true`. Required
# to run convex/seed.ts's dev-only mutations (seedDemoData, setDemoUserRole).
# This is a deployment-level switch, not per-user authorization (there is no
# auth yet - GER-217) - anyone with the deployment URL can call these
# mutations while it's set. Only set it on local/ephemeral dev deployments;
# never on production or on any shared/publicly-reachable deployment.
# ALLOW_DEV_SEED=true
