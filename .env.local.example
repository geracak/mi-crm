NEXT_PUBLIC_CONVEX_URL=
CONVEX_DEPLOYMENT=

# NOT read from this file - this is a Convex deployment environment variable,
# set per-deployment via `npx convex env set ALLOW_DEV_SEED true`. Required
# to run convex/seed.ts's dev-only functions (seedDemoData, setDemoUserRole).
# These are `internalMutation`s - Convex never exposes them to any client
# (browser, app code, or anyone with just the deployment URL), only to the
# authenticated Convex CLI/dashboard (`npx convex run seed:...`) or other
# server functions. This env var is an additional safety check on top of
# that, not the primary access control - still, never set it on production.
# ALLOW_DEV_SEED=true
